    "regex_rules": {
        "亮度": [
            {
                "pattern": "(\\d+)\\s*(流明|lumens|ANSI)",
                "action": "extract_and_classify",
                "thresholds": {
                    ">=3000": {
                        "label": "亮度满意",
                        "confidence": 0.9
                    },
                    "2000-2999": {
                        "label": "亮度够",
                        "confidence": 0.85
                    },
                    "1500-1999": {
                        "label": "亮度一般",
                        "confidence": 0.8
                    },
                    "<1500": {
                        "label": "亮度不足",
                        "confidence": 0.85
                    }
                },
                "weight": 1.0
            },
            {
                "pattern": "(白天|日光|开灯|不拉窗帘).{0,8}(清晰|能看|可以|也行|没问题)",
                "label": "白天清晰",
                "confidence": 0.9,
                "weight": 1.1
            },
            {
                "pattern": "(白天|日光|开灯).{0,8}(不行|看不清|不清楚|太暗)",
                "label": "白天看不清",
                "confidence": 0.9,
                "weight": 1.2
            }
        ],
        "清晰度/分辨率": [
            {
                "pattern": "(真|原生|物理|native)\\s*(4K|1080P|2K)",
                "action": "extract_resolution",
                "label_map": {
                    "真4K": {
                        "label": "真4K",
                        "confidence": 0.95
                    },
                    "原生4K": {
                        "label": "真4K",
                        "confidence": 0.95
                    },
                    "4K": {
                        "label": "4K清晰",
                        "confidence": 0.75
                    },
                    "真1080P": {
                        "label": "真1080P",
                        "confidence": 0.9
                    },
                    "1080P": {
                        "label": "高清",
                        "confidence": 0.8
                    }
                },
                "weight": 1.0
            },
            {
                "pattern": "抖?4K",
                "label": "抖4K",
                "confidence": 0.85,
                "weight": 0.9
            }
        ],
        "光源技术": [
            {
                "pattern": "(三色激光|三色光源|RGB激光)",
                "label": "三色激光",
                "confidence": 0.95,
                "weight": 1.0
            },
            {
                "pattern": "(\\d+)(小时|hrs|hours|h).*?(寿命|使用)",
                "action": "extract_lifespan",
                "thresholds": {
                    ">=30000": {
                        "label": "长寿命",
                        "confidence": 0.9
                    },
                    "20000-29999": {
                        "label": "寿命中等",
                        "confidence": 0.85
                    },
                    "<20000": {
                        "label": "寿命偏短",
                        "confidence": 0.8
                    }
                }
            }
        ],
        "投射比": [
            {
                "pattern": "(\\d+\\.\\d+)\\s*[::]\\s*1",
                "action": "extract_throw_ratio",
                "thresholds": {
                    "<0.3": {
                        "label": "超短焦",
                        "confidence": 0.95
                    },
                    "0.3-0.8": {
                        "label": "短焦",
                        "confidence": 0.9
                    },
                    ">0.8": {
                        "label": "长焦",
                        "confidence": 0.85
                    }
                }
            }
        ]
    },
